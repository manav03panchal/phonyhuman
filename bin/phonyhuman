#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────────────
# phonyhuman — CLI for Symphony + Claude Code
#
# Usage:
#   phonyhuman init [name]     Generate config + package skills
#   phonyhuman run <config>    Run the orchestrator
#   phonyhuman doctor          Check all prerequisites
#   phonyhuman version         Show version
#   phonyhuman update          Self-update from GitHub releases
#   phonyhuman help            Usage info
# ─────────────────────────────────────────────────────────────────────
set -euo pipefail

VERSION="dev"
PHONYHUMAN_HOME="${PHONYHUMAN_HOME:-$HOME/.phonyhuman}"
GITHUB_REPO="manav03panchal/phonyhuman"

# ── Path resolution ──────────────────────────────────────────────────
# When installed: PHONYHUMAN_HOME/bin/phonyhuman → PHONYHUMAN_HOME
# When running from repo: detect via script location
SCRIPT_PATH="$(cd "$(dirname "$0")" && pwd)"
if [[ -f "$PHONYHUMAN_HOME/version" ]]; then
    VERSION=$(cat "$PHONYHUMAN_HOME/version" 2>/dev/null || echo "dev")
    BIN_DIR="$PHONYHUMAN_HOME/bin"
    TEMPLATE_DIR="$PHONYHUMAN_HOME/templates"
else
    # Running from repo checkout
    BIN_DIR="$SCRIPT_PATH"
    REPO_ROOT="$(cd "$SCRIPT_PATH/.." && pwd)"
    TEMPLATE_DIR="$REPO_ROOT/templates"
    if [[ ! -d "$TEMPLATE_DIR" ]]; then
        TEMPLATE_DIR="$REPO_ROOT"
    fi
fi

SYMPHONY_ESCRIPT="$BIN_DIR/symphony-escript"
SHIM_PATH="$BIN_DIR/claude-shim.py"
LINEAR_CLI="$BIN_DIR/linear-cli.py"

# Skills directory (shipped alongside bin/)
if [[ -f "$PHONYHUMAN_HOME/version" ]]; then
    SKILLS_DIR="$PHONYHUMAN_HOME/skills"
else
    SKILLS_DIR="$REPO_ROOT/skills"
fi

# Fallback: look for files at repo-root locations (repo checkout)
if [[ ! -f "$SYMPHONY_ESCRIPT" && -f "$SCRIPT_PATH/../elixir/bin/symphony" ]]; then
    SYMPHONY_ESCRIPT="$SCRIPT_PATH/../elixir/bin/symphony"
fi
if [[ ! -f "$SHIM_PATH" && -f "$SCRIPT_PATH/../claude-shim.py" ]]; then
    SHIM_PATH="$SCRIPT_PATH/../claude-shim.py"
fi
if [[ ! -f "$LINEAR_CLI" && -f "$SCRIPT_PATH/../linear-cli.py" ]]; then
    LINEAR_CLI="$SCRIPT_PATH/../linear-cli.py"
fi

# ── Color helpers ────────────────────────────────────────────────────
if [[ -t 1 ]]; then
    bold()  { printf "\033[1m%s\033[0m" "$*"; }
    green() { printf "\033[32m%s\033[0m" "$*"; }
    red()   { printf "\033[31m%s\033[0m" "$*"; }
    cyan()  { printf "\033[36m%s\033[0m" "$*"; }
    dim()   { printf "\033[90m%s\033[0m" "$*"; }
    yellow(){ printf "\033[33m%s\033[0m" "$*"; }
else
    bold()  { printf "%s" "$*"; }
    green() { printf "%s" "$*"; }
    red()   { printf "%s" "$*"; }
    cyan()  { printf "%s" "$*"; }
    dim()   { printf "%s" "$*"; }
    yellow(){ printf "%s" "$*"; }
fi

die() { echo ""; red "  ERROR: $1"; echo ""; exit 1; }

# Return a user-private temp directory (mode 0700) for sensitive temp files.
# Prefers $XDG_RUNTIME_DIR (per-user, RAM-backed on most Linux),
# falls back to $PHONYHUMAN_HOME/tmp.
private_tmpdir() {
    local d="${XDG_RUNTIME_DIR:-}"
    if [[ -n "$d" && -d "$d" ]]; then
        d="$d/phonyhuman"
    else
        d="$PHONYHUMAN_HOME/tmp"
    fi
    mkdir -p "$d" && chmod 700 "$d"
    echo "$d"
}

banner() {
    echo ""
    echo "  🤪 $(bold "phonyhuman") $(dim "v$VERSION")"
    dim "  Autonomous issue orchestration powered by Claude Code"; echo ""
    echo ""
}

# ── Runtime detection ────────────────────────────────────────────────

# Find erl binary across common install locations
find_erlang() {
    # 1. Already on PATH
    if command -v erl &>/dev/null; then return 0; fi

    # 2. mise (preferred)
    if command -v mise &>/dev/null; then
        local mise_erl
        mise_erl="$(mise where erlang 2>/dev/null || true)"
        if [[ -n "$mise_erl" && -x "$mise_erl/bin/erl" ]]; then
            export PATH="$mise_erl/bin:$PATH"
            return 0
        fi
    fi

    # 3. asdf
    if [[ -d "$HOME/.asdf/installs/erlang" ]]; then
        local erl_bin
        erl_bin=$(find "$HOME/.asdf/installs/erlang" -name "erl" -type f -path "*/bin/erl" 2>/dev/null | head -1)
        if [[ -n "$erl_bin" ]]; then
            export PATH="$(dirname "$erl_bin"):$PATH"
            return 0
        fi
    fi

    # 4. Homebrew / system locations
    local search_dirs=(
        "/usr/local/lib/erlang/bin"
        "/opt/homebrew/lib/erlang/bin"
        "$HOME/.mise/installs/erlang"
    )
    for base in "${search_dirs[@]}"; do
        if [[ -d "$base" ]]; then
            local erl_bin
            erl_bin=$(find "$base" -name "erl" -type f -path "*/bin/erl" 2>/dev/null | head -1)
            if [[ -n "$erl_bin" ]]; then
                export PATH="$(dirname "$erl_bin"):$PATH"
                return 0
            fi
        fi
    done

    return 1
}

# Find elixir binary (needed for building from source)
find_elixir() {
    if command -v elixir &>/dev/null; then return 0; fi
    local search_dirs=(
        "$HOME/.elixir-install/installs"
        "$HOME/.asdf/installs/elixir"
        "$HOME/.mise/installs/elixir"
    )
    for base in "${search_dirs[@]}"; do
        if [[ -d "$base" ]]; then
            local elixir_bin
            elixir_bin=$(find "$base" -name "elixir" -type f -path "*/bin/elixir" 2>/dev/null | head -1)
            if [[ -n "$elixir_bin" ]]; then
                export PATH="$(dirname "$elixir_bin"):$PATH"
                # Also find corresponding erl
                local erl_bin
                erl_bin=$(find "$(dirname "$base")" -name "erl" -type f -path "*/bin/erl" 2>/dev/null | head -1)
                if [[ -n "$erl_bin" ]]; then
                    export PATH="$(dirname "$erl_bin"):$PATH"
                fi
                return 0
            fi
        fi
    done
    return 1
}

# Find PID(s) listening on a given TCP port using a portable fallback chain.
# Usage: find_pid_on_port PORT
# Prints space-separated PIDs to stdout. Returns 0 if any found, 1 otherwise.
find_pid_on_port() {
    local port="$1"
    local pids=""

    # 1. lsof — available on macOS by default, most full Linux installs
    if command -v lsof &>/dev/null; then
        pids=$(lsof -ti:"$port" 2>/dev/null || true)
        if [[ -n "$pids" ]]; then echo "$pids"; return 0; fi
    fi

    # 2. fuser — common on Linux (util-linux / psmisc)
    if command -v fuser &>/dev/null; then
        pids=$(fuser "$port/tcp" 2>/dev/null | tr -s ' ' '\n' | grep -E '^[0-9]+$' || true)
        if [[ -n "$pids" ]]; then echo "$pids"; return 0; fi
    fi

    # 3. ss — modern Linux (iproute2)
    if command -v ss &>/dev/null; then
        pids=$(ss -tlnp "sport = :$port" 2>/dev/null \
            | grep -o 'pid=[0-9]*' | cut -d= -f2 || true)
        if [[ -n "$pids" ]]; then echo "$pids"; return 0; fi
    fi

    # 4. netstat — fallback on older Linux / macOS
    if command -v netstat &>/dev/null; then
        pids=$(netstat -tlnp 2>/dev/null \
            | awk -v p="$port" '$4 ~ ":"p"$" {split($7,a,"/"); if(a[1]~/^[0-9]+$/) print a[1]}' || true)
        if [[ -n "$pids" ]]; then echo "$pids"; return 0; fi
    fi

    return 1
}

# Expected process names for the Symphony orchestrator (BEAM VM / escript).
SYMPHONY_PROC_NAMES="beam.smp beam escript erl"

# Check whether a PID belongs to a Symphony-related process.
# Usage: is_symphony_process PID
# Returns 0 if the process name matches an expected Symphony process, 1 otherwise.
is_symphony_process() {
    local pid="$1"
    local comm=""

    # Prefer /proc on Linux (no fork)
    if [[ -r "/proc/$pid/comm" ]]; then
        comm=$(cat "/proc/$pid/comm" 2>/dev/null) || return 1
    else
        # macOS / other: fall back to ps
        comm=$(ps -p "$pid" -o comm= 2>/dev/null) || return 1
        comm=$(basename "$comm")
    fi

    local name
    for name in $SYMPHONY_PROC_NAMES; do
        if [[ "$comm" == "$name" ]]; then
            return 0
        fi
    done
    return 1
}

# Filter a list of PIDs to only those belonging to Symphony processes.
# Usage: echo "$pids" | filter_symphony_pids
# Prints matching PIDs to stdout, one per line.
filter_symphony_pids() {
    local pid
    while read -r pid; do
        [[ -z "$pid" ]] && continue
        if is_symphony_process "$pid"; then
            echo "$pid"
        fi
    done
}

# Kill process(es) on a port and verify the port is freed.
# Only kills processes whose name matches a known Symphony process (beam.smp,
# escript, erl) to avoid killing unrelated services that happen to share the port.
# Usage: kill_and_verify_port_free PORT
# Returns 0 if port is free after kill, 1 if port remains occupied.
kill_and_verify_port_free() {
    local port="$1"
    local max_retries=5
    local attempt=0

    local all_pids
    all_pids=$(find_pid_on_port "$port" 2>/dev/null) || return 0  # nothing listening

    # Filter to only symphony-related processes
    local pids
    pids=$(echo "$all_pids" | filter_symphony_pids)
    if [[ -z "$pids" ]]; then
        yellow "  Port ${port} is in use by a non-symphony process — refusing to kill."; echo ""
        return 1
    fi

    dim "  Stopping existing symphony process on port ${port}..."; echo ""

    # Send SIGTERM only to verified symphony PIDs
    local pid
    for pid in $pids; do
        if is_symphony_process "$pid"; then
            kill "$pid" 2>/dev/null || true
        fi
    done

    # Verify port is freed, retrying up to max_retries times
    while (( attempt < max_retries )); do
        sleep 1
        if ! find_pid_on_port "$port" &>/dev/null; then
            return 0
        fi
        attempt=$((attempt + 1))
        if (( attempt == 2 )); then
            # Escalate to SIGKILL after 2 failed SIGTERM waits — re-verify identity
            local remaining
            remaining=$(find_pid_on_port "$port" 2>/dev/null | filter_symphony_pids) || return 0
            if [[ -z "$remaining" ]]; then
                yellow "  Port ${port} now held by a non-symphony process — aborting."; echo ""
                return 1
            fi
            for pid in $remaining; do
                if is_symphony_process "$pid"; then
                    kill -9 "$pid" 2>/dev/null || true
                fi
            done
        fi
    done

    red "  Could not free port ${port} after ${max_retries} attempts."; echo ""
    return 1
}

# Ensure Erlang runtime is available; auto-install via mise if possible
ensure_runtime() {
    if find_erlang; then return 0; fi

    echo ""
    yellow "  Erlang/OTP not found. Attempting auto-install via mise..."; echo ""

    # Install mise if needed
    if ! command -v mise &>/dev/null; then
        local mise_url="https://mise.jdx.dev/install.sh"
        echo ""
        yellow "  mise is not installed. phonyhuman needs mise to install Erlang/OTP."; echo ""
        yellow "  This will download and execute a script from:"; echo ""
        echo "    $mise_url"
        echo ""
        yellow "  Tip: set PHONYHUMAN_YES=1 to skip this prompt in automation."; echo ""
        echo ""

        if [[ "${PHONYHUMAN_YES:-}" != "1" ]]; then
            read -rp "  Proceed with mise installation? [y/N] " answer </dev/tty
            if [[ ! "$answer" =~ ^[Yy]$ ]]; then
                die "Aborted. Install mise manually:
  curl -sSL $mise_url | sh
  # Then retry: phonyhuman run <config>"
            fi
        fi

        echo "  Installing mise..."
        if curl -sSL "$mise_url" | sh 2>/dev/null; then
            export PATH="$HOME/.local/bin:$PATH"
        else
            die "Could not install mise. Install Erlang manually: https://mise.jdx.dev"
        fi
    fi

    # Use .mise.toml from PHONYHUMAN_HOME if available
    local mise_toml="$PHONYHUMAN_HOME/.mise.toml"
    if [[ -f "$mise_toml" ]]; then
        echo ""
        yellow "  Installing Erlang/OTP 28 via mise (this builds from source, ~10-15 min)..."; echo ""
        if (cd "$PHONYHUMAN_HOME" && mise trust 2>/dev/null && mise install 2>&1); then
            if find_erlang; then
                green "  Erlang installed successfully."; echo ""
                return 0
            fi
        fi
    fi

    # Direct install
    echo ""
    yellow "  Installing erlang@28 via mise (this builds from source, ~10-15 min)..."; echo ""
    if mise install erlang@28 2>&1; then
        mise use --global erlang@28 2>/dev/null || true
        if find_erlang; then
            green "  Erlang installed successfully."; echo ""
            return 0
        fi
    fi

    die "Could not install Erlang. Install manually:
  mise install erlang@28
  # or: https://www.erlang.org/downloads"
}

# ── Subcommands ──────────────────────────────────────────────────────

# phonyhuman help
cmd_help() {
    banner
    echo "  $(bold "USAGE")"
    echo "    phonyhuman <command> [arguments]"
    echo ""
    echo "  $(bold "COMMANDS")"
    echo "    init [name]        Generate config + package skills into .codex/skills/"
    echo "    run <config>       Run the orchestrator"
    echo "    doctor             Check all prerequisites"
    echo "    version            Show version"
    echo "    update             Self-update from GitHub releases"
    echo "    help               Show this help"
    echo ""
    echo "  $(bold "EXAMPLES")"
    echo "    phonyhuman init my-project"
    echo "    phonyhuman run my-project.toml"
    echo "    LINEAR_API_KEY=lin_api_... phonyhuman run my-project.toml"
    echo ""
    echo "  $(bold "ENVIRONMENT")"
    echo "    PHONYHUMAN_HOME    Install directory (default: ~/.phonyhuman)"
    echo "    LINEAR_API_KEY     Linear personal API token"
    echo "    SOURCE_REPO_URL    Git clone URL (overrides config)"
    echo ""
}

# phonyhuman version
cmd_version() {
    echo "phonyhuman $VERSION"
}

# ── Source subcommand modules ────────────────────────────────────────
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/lib/doctor.sh"
source "$SCRIPT_DIR/lib/init.sh"
source "$SCRIPT_DIR/lib/update.sh"
source "$SCRIPT_DIR/lib/run.sh"

# ── Main dispatch ────────────────────────────────────────────────────

main() {
    local cmd="${1:-help}"
    shift 2>/dev/null || true

    case "$cmd" in
        init)
            cmd_init "$@"
            ;;
        run)
            cmd_run "$@"
            ;;
        doctor|doc)
            cmd_doctor
            ;;
        version|--version|-V)
            cmd_version
            ;;
        update|upgrade)
            cmd_update
            ;;
        completions)
            cmd_completions "$@"
            ;;
        help|--help|-h)
            cmd_help
            ;;
        *)
            red "  Unknown command: $cmd"; echo ""
            echo ""
            cmd_help
            exit 1
            ;;
    esac
}

main "$@"
