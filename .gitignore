# ── User config (generated by phonyhuman init, contains secrets) ──
*.toml
!example.toml

# ── Secrets ──
.env
.env.*
credentials.json
*.pem
*.key

# ── TUI build artifacts ──
bin/symphony-tui
bin/symphony-tui-*

# ── Python ──
__pycache__/

# ── Elixir / Mix ──
elixir/_build/
elixir/deps/
elixir/cover/
elixir/*.ez
elixir/doc/

# ── OS junk ──
.DS_Store
Thumbs.db
*~

# ── Editor / IDE ──
.vscode/
.idea/
*.swp
*.swo

# ── Workspaces (runtime) ──
symphony-workspaces/
